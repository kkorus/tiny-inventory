# HTTP
PORT=3000
NODE_ENV=development

# CORS: comma-separated browser origins (web dev + Docker static port)
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# PostgreSQL (match docker-compose `db` service in development)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=tiny
DATABASE_PASSWORD=tiny
DATABASE_NAME=tiny_inventory
DATABASE_SYNCHRONIZE=false
# Set true for local dev if you do not run npm run db:migrate manually.
# Docker Compose server service sets DATABASE_MIGRATIONS_RUN=true so the first boot applies migrations.
DATABASE_MIGRATIONS_RUN=false
